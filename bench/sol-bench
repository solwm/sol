#!/usr/bin/env python3
"""sol-bench — drive a running sol via debug-ctl, collect metrics.

Usage:
    sol-bench --script SCRIPT [--socket PATH]

The script is a JSON file: a list of commands, each one a dict with at
least `cmd`. Special primitives recognised here (not by sol):

    {"sleep_ms": 50}              # wait — lets sol settle / animate
    {"repeat": N, "do": [ ... ]}  # nest a block of commands N times

Anything else is forwarded to sol as one line of JSON. Final
{"cmd": "shutdown"} is recommended so sol exits cleanly and dumps
metrics; if absent we send one ourselves at the end.

Examples:
    sol-bench --script bench/scripts/spawn_focus_close.json
    SOL_CTL_SOCKET=/run/user/1000/sol-ctl-wayland-1.sock sol-bench --script ...
"""
import argparse
import json
import os
import socket
import sys
import time
from pathlib import Path


def find_socket(explicit):
    if explicit:
        return explicit
    env = os.environ.get("SOL_CTL_SOCKET")
    if env:
        return env
    runtime = os.environ.get("XDG_RUNTIME_DIR", "/tmp")
    candidates = sorted(Path(runtime).glob("sol-ctl-*.sock"))
    if not candidates:
        sys.exit(f"no sol-ctl-*.sock found in {runtime} (is sol running with --features debug-ctl?)")
    if len(candidates) > 1:
        print(f"multiple sockets, picking newest: {candidates[-1]}", file=sys.stderr)
    return str(candidates[-1])


def connect(path, retries=20):
    """Try repeatedly while sol is still starting up."""
    last = None
    for _ in range(retries):
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.connect(path)
            return s
        except (FileNotFoundError, ConnectionRefusedError) as e:
            last = e
            time.sleep(0.1)
    sys.exit(f"connect {path}: {last}")


def send_cmd(sock, buf, cmd):
    """Write one line, read one line. `buf` accumulates partial reads."""
    sock.sendall((json.dumps(cmd) + "\n").encode())
    while b"\n" not in buf:
        chunk = sock.recv(4096)
        if not chunk:
            raise RuntimeError("sol closed the connection")
        buf += chunk
    line, _, rest = buf.partition(b"\n")
    return json.loads(line.decode()), rest


def run_script(sock, items, buf, ctx):
    """ctx: {"snapshots": [(label, dict), ...], "label": str}"""
    for item in items:
        # Harness-local primitives.
        if "sleep_ms" in item:
            time.sleep(item["sleep_ms"] / 1000.0)
            continue
        if "repeat" in item:
            for _ in range(int(item["repeat"])):
                buf = run_script(sock, item["do"], buf, ctx)
            continue
        if "label" in item:
            ctx["label"] = item["label"]
            sys.stderr.write(f"\n[{ctx['label']}] ")
            sys.stderr.flush()
            continue
        if "comment" in item:
            # Pure documentation — silently dropped, never sent to sol.
            continue

        # Anything else gets forwarded to sol.
        resp, buf = send_cmd(sock, buf, item)
        if not resp.get("ok", False):
            print(f"  ! {item}  →  {resp}", file=sys.stderr)
        else:
            sys.stderr.write(".")
            sys.stderr.flush()
        # `snapshot` is a sol command, but we want to capture each
        # one keyed by the most recent label so the user can see how
        # phases compare.
        if isinstance(item, dict) and item.get("cmd") == "snapshot":
            if resp.get("metrics"):
                ctx["snapshots"].append((ctx["label"], resp["metrics"]))
    return buf


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--script", required=True)
    ap.add_argument("--socket")
    ap.add_argument("--no-shutdown", action="store_true",
                    help="leave sol running after the script finishes")
    args = ap.parse_args()

    items = json.loads(Path(args.script).read_text())
    if not isinstance(items, list):
        sys.exit("script must be a JSON list of commands")

    path = find_socket(args.socket)
    sock = connect(path)
    buf = b""
    ctx = {"snapshots": [], "label": "start"}
    try:
        buf = run_script(sock, items, buf, ctx)
        sys.stderr.write("\n")
        # Always end with shutdown (or snapshot if --no-shutdown) so
        # we capture the final cumulative metrics.
        final_cmd = {"cmd": "shutdown"} if not args.no_shutdown else {"cmd": "snapshot"}
        resp, _ = send_cmd(sock, buf, final_cmd)
        final = resp.get("metrics") or resp
        ctx["snapshots"].append((ctx["label"] + " (final)", final))

        # Print all snapshots collected during the run, with deltas
        # so the user can read each phase as a standalone slice.
        # Deltas are computed against the previous snapshot in
        # capture order.
        out = {"snapshots": []}
        prev = None
        for label, snap in ctx["snapshots"]:
            entry = {"label": label, "cumulative": snap}
            if prev is not None:
                entry["delta_from_prev"] = {
                    k: snap[k] - prev[k]
                    for k in snap.keys()
                    if isinstance(snap.get(k), int)
                    and isinstance(prev.get(k), int)
                } | {
                    "frame_time_ms_buckets": [
                        a - b for a, b in zip(
                            snap["frame_time_ms_buckets"],
                            prev["frame_time_ms_buckets"],
                        )
                    ],
                }
            out["snapshots"].append(entry)
            prev = snap
        print(json.dumps(out, indent=2))
    finally:
        sock.close()


if __name__ == "__main__":
    main()
