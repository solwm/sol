[
  {"label": "baseline (idle)"},
  {"cmd": "snapshot"},

  {"label": "spawn 4 alacritty"},
  {"cmd": "spawn", "program": "alacritty"},
  {"sleep_ms": 400},
  {"cmd": "spawn", "program": "alacritty"},
  {"sleep_ms": 400},
  {"cmd": "spawn", "program": "alacritty"},
  {"sleep_ms": 400},
  {"cmd": "spawn", "program": "alacritty"},
  {"sleep_ms": 600},
  {"cmd": "snapshot"},

  {"label": "100 master-stack swaps"},
  {"repeat": 100, "do": [
    {"cmd": "move", "dir": "right"},
    {"sleep_ms": 30},
    {"cmd": "move", "dir": "left"},
    {"sleep_ms": 30}
  ]},
  {"cmd": "snapshot"},

  {"label": "50 focus cycles"},
  {"repeat": 50, "do": [
    {"cmd": "focus", "dir": "down"},
    {"sleep_ms": 16},
    {"cmd": "focus", "dir": "up"},
    {"sleep_ms": 16}
  ]},
  {"cmd": "snapshot"},

  {"label": "20 workspace switches"},
  {"repeat": 20, "do": [
    {"cmd": "workspace", "n": 2},
    {"sleep_ms": 250},
    {"cmd": "workspace", "n": 1},
    {"sleep_ms": 250}
  ]},
  {"cmd": "snapshot"},

  {"label": "10 zoom toggles"},
  {"repeat": 10, "do": [
    {"cmd": "toggle_zoom"},
    {"sleep_ms": 200},
    {"cmd": "toggle_zoom"},
    {"sleep_ms": 200}
  ]},
  {"cmd": "snapshot"}
]
